# =============================================================================
# MYJUNGLE – Docker Compose Environment Variables
# Copy to .env and adjust values for your environment.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=codeintel
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# -- Ollama (embedding provider) ----------------------------------------------
# Host-local Ollama (default for Docker Desktop):
OLLAMA_URL=http://host.docker.internal:11434
# Remote Ollama (uncomment and set if running on another host):
# OLLAMA_URL=http://your-ollama-host:11434
# PROVIDER_CONNECTIVITY_ALLOWED_HOSTS=your-ollama-host:11434
OLLAMA_MODEL=jina/jina-embeddings-v2-base-en

# -- Security -----------------------------------------------------------------
# Provider connectivity tests are restricted to this allowlist.
# Keep PROVIDER_CONNECTIVITY_ALLOWED_HOSTS in sync with OLLAMA_URL.
PROVIDER_CONNECTIVITY_ALLOWED_HOSTS=host.docker.internal:11434
# IMPORTANT: Change this in production! Used to encrypt provider credentials at rest.
PROVIDER_ENCRYPTION_SECRET=replace-this-provider-secret-replace-this-provider-secret
# IMPORTANT: Change this in production! Used to encrypt SSH private keys at rest.
SSH_KEY_ENCRYPTION_SECRET=replace-this-secret-replace-this-secret-replace-this-secret

# -- Backoffice (Next.js runtime via Docker Compose) --------------------------
# These values are used by the backoffice container in the full stack compose profile.
# For local frontend development outside Docker, use backoffice/.env.example instead.
API_BASE_URL=http://backend-api:8080
# IMPORTANT: Change this in production! Used to sign Better Auth sessions.
BETTER_AUTH_SECRET=replace-this-better-auth-secret-replace-this-better-auth-secret
# Public URL of the backoffice when exposed by docker-compose.yaml.
BETTER_AUTH_URL=http://localhost:5173
# Optional OIDC settings:
# OIDC_DISCOVERY_URL=https://your-oidc-provider.example.com/.well-known/openid-configuration
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
NEXT_PUBLIC_OIDC_PROVIDER_ID=oidc

# -- Image overrides (optional, for pre-built images) -------------------------
# BACKEND_API_IMAGE=myjungle/backend-api:local
# BACKEND_WORKER_IMAGE=myjungle/backend-worker:local
# MCP_SERVER_IMAGE=myjungle/mcp-server:local
# BACKOFFICE_IMAGE=myjungle/backoffice:local
