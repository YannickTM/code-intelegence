{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myjungle.dev/contracts/redis/worker-status.v1.schema.json",
  "title": "Worker Status v1",
  "description": "Ephemeral Redis worker-registry payload written by backend-worker instances for observability and lightweight coordination. Advisory only; PostgreSQL remains the source of truth for job execution state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_id",
    "status",
    "started_at",
    "last_heartbeat_at",
    "supported_workflows"
  ],
  "properties": {
    "worker_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Stable process or instance identifier for the worker lifecycle."
    },
    "status": {
      "type": "string",
      "enum": [
        "starting",
        "idle",
        "busy",
        "draining",
        "stopped"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_heartbeat_at": {
      "type": "string",
      "format": "date-time"
    },
    "hostname": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "current_job_id": {
      "type": "string",
      "format": "uuid"
    },
    "current_project_id": {
      "type": "string",
      "format": "uuid"
    },
    "supported_workflows": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "full-index",
          "incremental-index",
          "code-analysis",
          "rag-file",
          "rag-repo",
          "agent-run"
        ]
      }
    },
    "drain_reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    }
  },
  "examples": [
    {
      "worker_id": "worker-7f8cb7f9d8-z9j4x",
      "status": "busy",
      "started_at": "2026-03-08T12:00:00Z",
      "last_heartbeat_at": "2026-03-08T12:05:10Z",
      "hostname": "worker-7f8cb7f9d8-z9j4x",
      "version": "backend-worker@v0.1.0",
      "current_job_id": "69dc1de1-5ad3-4ea4-b0f0-f4ad9d1f5ff4",
      "current_project_id": "a8f3d8f6-0e37-45e0-8826-1ce6f57f2244",
      "supported_workflows": [
        "full-index",
        "incremental-index"
      ]
    }
  ]
}
