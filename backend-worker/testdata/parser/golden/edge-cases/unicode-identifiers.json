      "ChunkID": "unicode-identifiers.py:function:3-9",
      "SymbolID": "sym_fa82b47b0421b15f",
      "ChunkType": "function",
      "ChunkHash": "571cb9e25c79132e7d4577426eefac93af79e810822ff75192c9b6c04d7ab289",
      "Content": "# CJK identifiers\ndef 计算总和(数据列表):\n    \"\"\"Calculate the sum of a list of numbers.\"\"\"\n    总和 = 0\n    for 数字 in 数据列表:\n        总和 += 数字\n    return 总和",
      "ContextBefore": "File: unicode-identifiers.py \u003e function 计算总和",
      "ContextAfter": "",
      "StartLine": 3,
      "EndLine": 9,
      "EstimatedTokens": 48,
      "OwnerQualifiedName": "计算总和",
      "OwnerKind": "function",
      "IsExportedContext": true,
      "SemanticRole": "api_surface"
    },
    {
      "ChunkID": "unicode-identifiers.py:function:11-14",
      "SymbolID": "sym_ba7dd183abad0a85",
      "ChunkType": "function",
      "ChunkHash": "cd4dcf6223045bc967db2151d1c37ad15301cb2aeaf3796288a1b1aab828fd26",
      "Content": "# Accented Latin identifiers\ndef créer_utilisateur(prénom, nom_de_famille):\n    \"\"\"Create a user with accented names.\"\"\"\n    return {\"prénom\": prénom, \"nom\": nom_de_famille}",
      "ContextBefore": "File: unicode-identifiers.py \u003e function créer_utilisateur",
      "ContextAfter": "",
      "StartLine": 11,
      "EndLine": 14,
      "EstimatedTokens": 45,
      "OwnerQualifiedName": "créer_utilisateur",
      "OwnerKind": "function",
      "IsExportedContext": true,
      "SemanticRole": "api_surface"
    },
    {
      "ChunkID": "unicode-identifiers.py:function:16-20",
      "SymbolID": "sym_fb5ab532cf2215f2",
      "ChunkType": "function",
      "ChunkHash": "ce097e4a9a9d0be314de9f0e597ba5c825b17ce5ef7ae2508fbbb39de190fa0a",
      "Content": "# Greek letter identifiers\ndef calculate_Δ(α, β, γ):\n    \"\"\"Calculate discriminant using Greek letters.\"\"\"\n    Δ = β ** 2 - 4 * α * γ\n    return Δ",
      "ContextBefore": "File: unicode-identifiers.py \u003e function calculate_Δ",
      "ContextAfter": "",
      "StartLine": 16,
      "EndLine": 20,
      "EstimatedTokens": 39,
      "OwnerQualifiedName": "calculate_Δ",
      "OwnerKind": "function",
      "IsExportedContext": true,
      "SemanticRole": "api_surface"
    },
    {
      "ChunkID": "unicode-identifiers.py:function:37-44",
      "SymbolID": "sym_9d841826120f88d1",
      "ChunkType": "function",
      "ChunkHash": "578d80c5192638559bb1fa5fc3b134c24bda3050518fe1de8a70437659c2b5a2",
      "Content": "def résumé_parser(texte_entrée):\n    \"\"\"Parse a résumé from input text.\"\"\"\n    données = texte_entrée.strip().split(\"\\n\")\n    résultat = []\n    for ligne in données:\n        if ligne:\n            résultat.append(ligne)\n    return résultat",
      "ContextBefore": "File: unicode-identifiers.py \u003e function résumé_parser",
      "ContextAfter": "",
      "StartLine": 37,
      "EndLine": 44,
      "EstimatedTokens": 63,
      "OwnerQualifiedName": "résumé_parser",
