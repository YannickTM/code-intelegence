      "ChunkHash": "97a013d9db4c66a63438ace0feffe889981c4426f01b5969475de3ae82d80f23",
      "Content": "interface UserListProps {\n  endpoint: string;\n  pageSize?: number;\n  theme?: Theme;\n}",
      "ContextBefore": "File: typescript/react-component.tsx \u003e interface UserListProps",
      "ContextAfter": "",
      "StartLine": 15,
      "EndLine": 19,
      "EstimatedTokens": 22,
