      "Content": "# Build the Docker image with the current git tag.\nbuild_image() {\n    log_info \"Building image ${IMAGE}\"\n    docker build \\\n        --build-arg \"GIT_SHA=${DEPLOY_TAG}\" \\\n        --build-arg \"BUILD_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)\" \\\n        -t \"${IMAGE}\" \\\n        -f docker/Dockerfile .\n}",
