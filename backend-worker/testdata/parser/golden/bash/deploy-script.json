      "Content": "# --- Main ---\nmain() {\n    log_info \"Starting deployment for env=${DEPLOY_ENV} tag=${DEPLOY_TAG}\"\n    build_image\n    push_image\n    run_migrations\n    deploy_to_cluster\n    run_smoke_test\n    log_info \"Deployment complete\"\n}",
