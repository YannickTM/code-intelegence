      "ChunkHash": "8d4eda2228b11d65c6be93f800053cb29852c9ed5eb388ee82af0f76b9592fba",
      "Content": "# Run database migrations before deployment.\nrun_migrations() {\n    local db_url\n    db_url=\"$(get_config \"${DEPLOY_ENV}\" \"database_url\")\"\n    log_info \"Running migrations against ${DEPLOY_ENV}\"\n    ./bin/migrate --url \"${db_url}\" --direction up\n}",
