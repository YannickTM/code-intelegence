    {
      "ChunkID": "bash/deploy-script.sh:function:52-66",
      "SymbolID": "sym_5611bb6a6eed3cd8",
      "ChunkType": "function",
      "ChunkHash": "2c19c2659775e7b2e35abfe83ae2a167e077ea768fb3b65b120636f4ac94074d",
      "Content": "# Deploy to the target Kubernetes cluster.\ndeploy_to_cluster() {\n    local namespace=\"web-${DEPLOY_ENV}\"\n    log_info \"Deploying to namespace ${namespace}\"\n\n    kubectl set image \\\n        \"deployment/web-service\" \\\n        \"web-service=${IMAGE}\" \\\n        --namespace \"${namespace}\"\n\n    kubectl rollout status \\\n        \"deployment/web-service\" \\\n        --namespace \"${namespace}\" \\\n        --timeout=300s\n}",
      "ContextBefore": "File: bash/deploy-script.sh \u003e function deploy_to_cluster",
      "ContextAfter": "",
