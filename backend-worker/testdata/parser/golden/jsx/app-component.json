  "Chunks": [
    {
      "ChunkID": "jsx/app-component.jsx:module_context:1-15",
      "SymbolID": "",
      "ChunkType": "module_context",
      "ChunkHash": "df7174e76e4adae90b8905ce71c7cd1d5eae9f869dfb8e005c3d7a8da2b4f00f",
      "Content": "import React, { useState, Fragment } from \"react\";\nimport { BrowserRouter, Route, Switch } from \"react-router-dom\";\nimport Header from \"./components/Header\";\nimport Sidebar from \"./components/Sidebar\";\nimport Dashboard from \"../pages/Dashboard\";\nimport Settings from \"../pages/Settings\";\n\n/**\n * Navigation item used in the sidebar.\n */\nconst NAV_ITEMS = [\n  { path: \"/\", label: \"Dashboard\", icon: \"home\" },\n  { path: \"/settings\", label: \"Settings\", icon: \"gear\" },\n];\n",
      "ContextBefore": "",
      "ContextAfter": "",
      "StartLine": 1,
      "EndLine": 15,
      "EstimatedTokens": 118,
      "OwnerQualifiedName": "",
      "OwnerKind": "",
      "IsExportedContext": false,
      "SemanticRole": "implementation"
    },
    {
      "ChunkID": "jsx/app-component.jsx:function:16-45",
      "SymbolID": "sym_53f4dd53997b2a3c",
      "ChunkType": "function",
      "ChunkHash": "a15b3305303bf61a6d08340905acbecbeb2dc91e34c439a1475c617133067f71",
      "Content": "/**\n * Main application shell with routing and layout.\n */\nexport default function App() {\n  const [sidebarOpen, setSidebarOpen] = useState(true);\n  const [theme, setTheme] = useState(\"light\");\n\n  const toggleSidebar = () =\u003e setSidebarOpen((prev) =\u003e !prev);\n\n  return (\n    \u003cBrowserRouter\u003e\n      \u003cdiv className={`app-container theme-${theme}`}\u003e\n        \u003cHeader onMenuClick={toggleSidebar} title=\"My App\" /\u003e\n        \u003cdiv className=\"app-body\"\u003e\n          \u003cSidebar open={sidebarOpen} items={NAV_ITEMS} /\u003e\n          \u003cmain className=\"app-content\"\u003e\n            \u003cSwitch\u003e\n              \u003cRoute exact path=\"/\"\u003e\n                \u003cDashboard /\u003e\n              \u003c/Route\u003e\n              \u003cRoute path=\"/settings\"\u003e\n                \u003cSettings theme={theme} onThemeChange={setTheme} /\u003e\n              \u003c/Route\u003e\n            \u003c/Switch\u003e\n          \u003c/main\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/BrowserRouter\u003e\n  );\n}",
      "ContextBefore": "File: jsx/app-component.jsx \u003e function App",
      "ContextAfter": "",
      "StartLine": 16,
      "EndLine": 45,
      "EstimatedTokens": 220,
      "OwnerQualifiedName": "App",
      "OwnerKind": "function",
      "IsExportedContext": true,
      "SemanticRole": "ui_component"
    },
    {
      "ChunkID": "jsx/app-component.jsx:function:47-67",
      "SymbolID": "sym_bd02a716405862a8",
      "ChunkType": "function",
      "ChunkHash": "19e30f49e918ba9dda4dfd1240492153cd9bfb315bc0194baef27cc8481f4c0e",
      "Content": "/**\n * Simple status badge component.\n */\nexport const StatusBadge = ({ status, label }) =\u003e {\n  const colorMap = {\n    success: \"green\",\n    warning: \"orange\",\n    error: \"red\",\n  };\n\n  return (\n    \u003cFragment\u003e\n      \u003cspan\n        className=\"status-badge\"\n        style={{ backgroundColor: colorMap[status] || \"gray\" }}\n      \u003e\n        {label || status}\n      \u003c/span\u003e\n    \u003c/Fragment\u003e\n  );\n};",
      "ContextBefore": "File: jsx/app-component.jsx \u003e function StatusBadge",
      "ContextAfter": "",
      "StartLine": 47,
      "EndLine": 67,
      "EstimatedTokens": 98,
      "OwnerQualifiedName": "StatusBadge",
      "OwnerKind": "function",
      "IsExportedContext": true,
      "SemanticRole": "ui_component"
    },
    {
      "ChunkID": "jsx/app-component.jsx:function:69-81",
      "SymbolID": "sym_a095490b67c6173f",
      "ChunkType": "function",
      "ChunkHash": "8add62c66853a6cded807acd2cfc9002b64f8972b4cdcaf3c2977818debd85b1",
      "Content": "/**\n * Empty state placeholder for lists.\n */\nexport function EmptyState({ message }) {\n  return (\n    \u003c\u003e\n      \u003cdiv className=\"empty-state\"\u003e\n        \u003cimg src=\"/images/empty.svg\" alt=\"No data\" /\u003e\n        \u003cp\u003e{message}\u003c/p\u003e\n      \u003c/div\u003e\n    \u003c/\u003e\n  );\n}",
      "ContextBefore": "File: jsx/app-component.jsx \u003e function EmptyState",
