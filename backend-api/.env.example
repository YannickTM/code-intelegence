# backend-api standalone environment example
#
# Keep keys sorted alphabetically to satisfy dotenv-linter.

CORS_ALLOWED_ORIGINS=http://localhost:3000
EMBED_BATCH_SIZE=64
EMBEDDING_PROVIDER=ollama
INDEX_FULL_TIMEOUT=30m
INDEX_INCREMENTAL_TIMEOUT=10m
INDEXING_DEFAULT_BRANCH=main
INDEXING_MAX_CHUNK_TOKENS=512
INDEXING_MAX_PARALLEL_FILES=8
LLM_MODEL=codellama:7b
LLM_PROVIDER=ollama
LLM_URL=http://localhost:11434
MAX_RETRIES=3
MAX_SSE_CONNECTIONS=100
OLLAMA_DIMENSIONS=768
OLLAMA_MODEL=jina/jina-embeddings-v2-base-en
OLLAMA_URL=http://localhost:11434
POSTGRES_DSN=postgres://app:app@localhost:5432/codeintel?sslmode=disable
POSTGRES_MAX_CONN_LIFE=30m
POSTGRES_MAX_CONNS=25
POSTGRES_MIN_CONNS=5
PROVIDER_CONNECTIVITY_ALLOWED_HOSTS=localhost:11434,127.0.0.1:11434,host.docker.internal:11434
PROVIDER_ENCRYPTION_SECRET=replace-this-with-a-different-long-random-secret
REDIS_POOL_SIZE=10
REDIS_URL=redis://localhost:6379/0
REPO_CACHE_DIR=/var/lib/myjungle/repos
SERVER_BODY_LIMIT_BYTES=1048576
SERVER_PORT=8080
SESSION_COOKIE_NAME=session
SESSION_SECURE_COOKIE=false
SESSION_TTL=24h
SSE_KEEPALIVE_INTERVAL=30s
SSH_KEY_ENCRYPTION_SECRET=replace-this-with-a-long-random-secret
UNIQUE_WINDOW=1h
WORKER_CONCURRENCY=4
