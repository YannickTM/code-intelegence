# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Go backend API base URL (no trailing slash)
API_BASE_URL="http://localhost:8080"

# ── BetterAuth + OIDC ────────────────────────────────────────────────────────
# Secret for signing BetterAuth sessions/tokens (min 32 chars)
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-secret-value"

# Public URL of this Next.js app (used for OIDC callback URLs)
BETTER_AUTH_URL="http://localhost:3000"

# OIDC provider discovery URL (the /.well-known/openid-configuration endpoint)
# Uncomment when you have an OIDC provider configured:
# OIDC_DISCOVERY_URL="https://your-oidc-provider.example.com/.well-known/openid-configuration"

# OIDC client credentials (from your IAM provider: WorkOS, Keycloak, etc.)
# OIDC_CLIENT_ID="your-client-id"
# OIDC_CLIENT_SECRET="your-client-secret"

# Client-side OIDC provider identifier (matches the genericOAuth providerId)
NEXT_PUBLIC_OIDC_PROVIDER_ID="oidc"
